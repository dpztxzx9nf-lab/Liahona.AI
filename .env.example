# Liahona local environment example.
# Copy values into .env locally. Do not commit real credentials.

DISCORD_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
PORT=3000
DEV_PORTAL_TOKEN=

# Live source access is disabled by default.
LIVE_SOURCES_ENABLED=false
GOOGLE_SEARCH_ENABLED=false
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
X_SEARCH_ENABLED=false
X_BEARER_TOKEN=
LIVE_SOURCE_TIMEOUT_MS=3000
LIVE_SOURCE_MAX_RESULTS=5
